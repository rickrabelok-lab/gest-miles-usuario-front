    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Mapeia a resposta Evolution -> { tenant_id, groups:[{jid,nome,size}] }.\n// A resposta pode vir como array direto OU dentro de $json (confirmar no piloto).\nconst raw = $input.all().map((i) => i.json)\nconst arr = Array.isArray(raw) && raw.length && raw[0].id ? raw : (raw[0]?.data ?? raw)\nconst groups = (Array.isArray(arr) ? arr : [])\n  .filter((g) => g && g.id && String(g.id).endsWith('@g.us'))\n  .map((g) => ({ jid: g.id, nome: g.subject || '', size: g.size ?? null }))\nreturn [{ json: { tenant_id: 3, groups } }]"
      },
      "id": "gmgo-prep",
      "name": "gmgo-prep",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://gest-miles-usuario-front-slzj.vercel.app/api/agent/group-onboarding",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ tenant_id: $json.tenant_id, groups: $json.groups }) }}",
        "options": {}
