      "notes": "Rota deploya no merge do PR (backend Vercel). Até lá, apontar pra URL de preview no piloto."
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Relatório do onboarding pro grupo interno.\nconst r = $json\nconst rev = Array.isArray(r.revisar) ? r.revisar : []\nlet msg = `*\\ud83d\\udc65 Onboarding de grupos*\\n\\n` +\n  `Descobertos: ${r.descobertos ?? 0}\\n` +\n  `\\u2705 Auto-mapeados: ${r.auto_mapeados ?? 0}\\n` +\n  `\\u2139\\ufe0f Já mapeados: ${r.ja_mapeados ?? 0}\\n` +\n  `\\u26a0\\ufe0f Revisar: ${rev.length}`\nif (rev.length) {\n  msg += `\\n\\n*Revisar (sem match único):*\\n` +\n    rev.slice(0, 30).map((x) => `\\u2022 ${x.grupo} \\u2014 ${x.candidatos.length ? x.candidatos.join(', ') : 'nenhum candidato'}`).join('\\n')\n  if (rev.length > 30) msg += `\\n… +${rev.length - 30}`\n}\nreturn [{ json: { mensagem: msg } }]"
      },
