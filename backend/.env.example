# Servidor Node (Express) — copie para backend/.env

PORT=3000

# Mesmo projeto Supabase que o front (Settings → API).
# Aplique as migrations em supabase/migrations/ (ex.: bonus_offers, calendar_prices, demo_flights).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Reservado para rotas que precisem bypass RLS (não usado pelo código atual do router principal).
# Nunca expor no front nem em builds Vite.
# Obrigatório para: reset de senha por e-mail, convites, vínculo organização (rotas /api/auth/* estendidas, /api/invites, /api/registration).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# URL pública do front (links nos e-mails). Ex.: https://app.seudominio.com ou http://localhost:3080
PUBLIC_APP_URL=http://localhost:3080

# Brevo — Transactional emails (https://app.brevo.com → SMTP & API → API Keys)
# Coloque a chave real em backend/.env (nunca commite chaves reais).
BREVO_API_KEY=xkeysib-replace-with-your-brevo-api-key
# E-mail remetente já verificado no domínio da Brevo (Senders → Domains).
BREVO_SENDER_EMAIL=rick.rabelok@gmail.com
BREVO_SENDER_NAME=Gest Miles

# Stripe (monetização — mesmo projeto que o front se usar STRIPE_* na raiz via load-env)
STRIPE_SECRET_KEY=sk_test_replace
STRIPE_WEBHOOK_SECRET=whsec_replace
