# Servidor Node (Express) — copie para backend/.env

PORT=3000

# Mesmo projeto Supabase que o front (Settings → API).
# Aplique as migrations em supabase/migrations/ (ex.: bonus_offers, calendar_prices, demo_flights).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Reservado para rotas que precisem bypass RLS (não usado pelo código atual do router principal).
# Nunca expor no front nem em builds Vite.
# Obrigatório para: reset de senha por e-mail, convites, vínculo organização (rotas /api/auth/* estendidas, /api/invites, /api/registration).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# URL pública do front (links nos e-mails). Ex.: https://app.seudominio.com ou http://localhost:3080
PUBLIC_APP_URL=http://localhost:3080

# Resend — Transactional emails (https://resend.com → API Keys).
# Coloque a chave real em backend/.env (nunca commite chaves reais).
RESEND_API_KEY=re_replace-with-your-resend-api-key
# Remetente (OPCIONAL). Default no código: "Gest Miles <nao-responda@mail.gestmiles.com.br>"
# (domínio já verificado no Resend). Só sete se quiser sobrescrever. Aceita "Nome <email@dominio>" ou só "email@dominio".
# RESEND_FROM=
# RESEND_FROM_NAME=Gest Miles

# Legado — Brevo (mantido só como referência de rollback; o código não lê mais estas vars).
# BREVO_API_KEY=
# BREVO_SENDER_EMAIL=
# BREVO_SENDER_NAME=Gest Miles

# Caixa que recebe as mensagens do "Fale Conosco" (default no código: gestmilesapp@gmail.com).
CONTACT_INBOX_EMAIL=gestmilesapp@gmail.com

# Stripe (monetização — mesmo projeto que o front se usar STRIPE_* na raiz via load-env)
STRIPE_SECRET_KEY=sk_test_replace
STRIPE_WEBHOOK_SECRET=whsec_replace

# CORS - allowed origins separated by comma in production
CORS_ORIGINS=https://gestmiles.com.br,https://www.gestmiles.com.br


# Program access encryption - used by /api/program-access. Use a long random secret in production.
PROGRAM_ACCESS_ENCRYPTION_KEY=change-me-long-random-secret

# Observabilidade (Sentry). Reusa o projeto do manager; separado por environment/tag.
# Sem DSN, o Sentry fica desativado (no-op).
# SENTRY_DSN=
# SENTRY_ENV=usuario-backend

# Billing B2B — Cron de reconcile diário.
# Segredo compartilhado entre o cron da Vercel e este backend.
# Gerar com: openssl rand -hex 32
# Configurar também como env var na Vercel (CRON_SECRET). O cron passa no header x-cron-secret.
# PUBLIC_MANAGER_URL: URL do CRM (manager) — usado nos redirects de checkout e portal B2B.
# CRON_SECRET=change-me-long-random-secret
# PUBLIC_MANAGER_URL=https://manager.gestmiles.com.br

# Fase C — resumo de demandas pro n8n (server-to-server). Gere uma chave longa
# aleatória (ex.: openssl rand -hex 32) e cadastre a MESMA em credencial do n8n.
AGENT_API_KEY=
