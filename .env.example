# Backend (backend/.env)
PORT=3000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Frontend - quando usar backend separado (ex: Lovable)
VITE_API_URL=http://localhost:3000

# Frontend - Supabase direto (quando VITE_API_URL não está definido)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Nome da empresa de gestão no cabeçalho do painel /cs (texto público no bundle).
# Se omitir, o app usa o padrão "Gestão João Carvalho".
# VITE_GESTAO_NOME_EMPRESA=Minha Empresa de Gestão
