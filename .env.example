# Raiz do app usuário (Vite) — copie para .env.local

# Onde a equipa interna deve ser redirecionada (não é o domínio do app de clientes).
# CS / gestor / admin_equipe → Manager | admin → painel Admin (gest-miles-admin-front, :3000 por defeito).
# VITE_MANAGER_APP_URL=http://localhost:3081
# VITE_ADMIN_APP_URL=http://localhost:3000

# Stripe (checkout/pagamentos no browser — chave publishable)
# VITE_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Supabase (obrigatório para auth e dados)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# BFF (Express em ./backend) — necessário para recuperação de senha via Brevo (e convites, etc.).
# Sem esta variável, o front usa o e-mail NATIVO do Supabase Auth em /auth/forgot-password (não é Brevo).
# Em dev (Vite :3080 + proxy): VITE_API_URL=/  → pedidos a /api/* são enviados ao Express em 127.0.0.1:3000.
# Em produção ou sem proxy: URL absoluta do Express, ex.: VITE_API_URL=https://api.seudominio.com
# Deploy Vercel neste repo = só o front (ver .vercelignore). Hospeda o backend à parte e aponta VITE_API_URL para essa URL.

# Nome no cabeçalho do painel gestor
# VITE_GESTAO_NOME_EMPRESA=Minha empresa

# Splash inicial inteligente (ms)
# VITE_SPLASH_MIN_MS=1200
# VITE_SPLASH_MAX_MS=4000

# URL pública do app (usada no link de recuperação de senha enviado por e-mail).
# Defina no Vercel → Settings → Environment Variables para produção.
# Sem isto, o app usa window.location.origin (correto quando o domínio está na whitelist do Supabase).
# Exemplo: VITE_APP_URL=https://app.gestmiles.com.br
# VITE_APP_URL=

# Páginas legais (LGPD) linkadas no cadastro/aviso de cookies.
# Default no código: https://gestmiles.com.br/{termos,privacidade,cookies}.
# Sobrescreva a base OU cada URL individual se necessário.
# VITE_LEGAL_BASE_URL=https://gestmiles.com.br
# VITE_LEGAL_TERMS_URL=
# VITE_LEGAL_PRIVACY_URL=
# VITE_LEGAL_COOKIES_URL=

# Observabilidade (Sentry). Reusa o projeto do manager; separado por environment/tag.
# Sem DSN, o Sentry fica desativado (no-op).
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENV=usuario-front

# E2E (Playwright). Credenciais da conta de teste — NÃO commitar valores reais.
# E2E_BASE_URL default http://localhost:3081 (ou aponte pra uma URL deployada).
# E2E_BASE_URL=
# E2E_EMAIL=
# E2E_PASSWORD=

# Compat: alguns ambientes usam API_URL (api.ts aceita VITE_API_URL ou API_URL)
# API_URL=http://localhost:3000
